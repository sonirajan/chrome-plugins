{
  "manifest_version": 3,
  "name": "LinkedIn Image Blocker",
  "version": "1.0.0",
  "description": "Blocks all LinkedIn member profile images and photos for distraction-free browsing.",
  "permissions": [],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://*.licdn.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["blocker.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LinkedIn Image Blocker"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
